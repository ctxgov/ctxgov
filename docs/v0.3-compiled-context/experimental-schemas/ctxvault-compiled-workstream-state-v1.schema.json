{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.ctxvault/experimental/ctxvault-compiled-workstream-state-v1.schema.json",
  "title": "CtxVault Compiled Workstream State",
  "description": "Experimental read-model contract for compiled current workstream truth plus evidence timeline. This is not a canonical core object.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "state_id",
    "workstream_ref",
    "generated_at",
    "contract_state",
    "source_refs",
    "current_truth",
    "evidence_timeline",
    "review",
    "projection_targets",
    "density",
    "warnings"
  ],
  "properties": {
    "schema_id": {
      "type": "string",
      "enum": ["ctxvault.compiled-workstream-state/v1"]
    },
    "state_id": {
      "type": "string",
      "pattern": "^cws_"
    },
    "workstream_ref": {
      "$ref": "#/$defs/Reference"
    },
    "generated_at": {
      "$ref": "#/$defs/Timestamp"
    },
    "contract_state": {
      "type": "string",
      "enum": ["experimental_read_model"]
    },
    "source_refs": {
      "$ref": "#/$defs/ReferenceArray"
    },
    "current_truth": {
      "$ref": "#/$defs/CurrentTruth"
    },
    "evidence_timeline": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EvidenceEvent"
      }
    },
    "review": {
      "$ref": "#/$defs/ReviewState"
    },
    "projection_targets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ProjectionTarget"
      }
    },
    "density": {
      "$ref": "#/$defs/DensityState"
    },
    "warnings": {
      "$ref": "#/$defs/StringArray"
    }
  },
  "$defs": {
    "Reference": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9+.-]*://.+"
    },
    "ReferenceArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Reference"
      },
      "default": []
    },
    "StringArray": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "SourcedText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "source_refs"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "$ref": "#/$defs/ReferenceArray"
        }
      }
    },
    "CurrentTruth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "summary",
        "active_decisions",
        "active_constraints",
        "open_questions",
        "next_actions",
        "reusable_judgments"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "$ref": "#/$defs/SourcedText"
        },
        "active_decisions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourcedText"
          }
        },
        "active_constraints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourcedText"
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourcedText"
          }
        },
        "next_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourcedText"
          }
        },
        "reusable_judgments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourcedText"
          }
        }
      }
    },
    "EvidenceEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_ref",
        "event_kind",
        "occurred_at",
        "summary",
        "source_refs",
        "review_state"
      ],
      "properties": {
        "event_ref": {
          "$ref": "#/$defs/Reference"
        },
        "event_kind": {
          "type": "string",
          "enum": [
            "source_import",
            "candidate_review",
            "prompt_patch_review",
            "projection_write",
            "receipt_emit",
            "owner_decision"
          ]
        },
        "occurred_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "$ref": "#/$defs/ReferenceArray"
        },
        "review_state": {
          "type": "string",
          "enum": ["approved", "rejected", "proposed", "not_required"]
        }
      }
    },
    "ReviewState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approval_state", "required_before_projection", "receipt_refs"],
      "properties": {
        "approval_state": {
          "type": "string",
          "enum": ["approved_inputs_only", "contains_proposed_inputs", "blocked"]
        },
        "required_before_projection": {
          "type": "boolean"
        },
        "receipt_refs": {
          "$ref": "#/$defs/ReferenceArray"
        }
      }
    },
    "ProjectionTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_kind", "status", "receipt_ref"],
      "properties": {
        "target_kind": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["not_projected", "projected", "blocked"]
        },
        "receipt_ref": {
          "type": ["string", "null"],
          "pattern": "^[A-Za-z][A-Za-z0-9+.-]*://.+"
        }
      }
    },
    "DensityState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary_word_count",
        "summary_budget",
        "warning_count",
        "warnings"
      ],
      "properties": {
        "summary_word_count": {
          "type": "integer",
          "minimum": 0
        },
        "summary_budget": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_min", "target_max", "hard_warning"],
          "properties": {
            "target_min": {
              "type": "integer",
              "minimum": 0
            },
            "target_max": {
              "type": "integer",
              "minimum": 0
            },
            "hard_warning": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "warning_count": {
          "type": "integer",
          "minimum": 0
        },
        "warnings": {
          "$ref": "#/$defs/StringArray"
        }
      }
    }
  }
}
