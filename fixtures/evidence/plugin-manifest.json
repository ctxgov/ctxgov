{
  "schema_version": "ctxvault.plugin-manifest/v1",
  "id": "portable-harness-projection",
  "version": "0.1.0",
  "display_name": "Portable Harness Projection",
  "description": "Renders approved workstream context into portable harness projection files.",
  "kind": "projection",
  "capabilities": [
    "projection.harness.agents-md",
    "projection.harness.claude-md",
    "projection.wiki.markdown-workstream",
    "projection.harness.portable-agent-tree"
  ],
  "runtime": "deterministic-local",
  "accepted_inputs": [
    "Workstream",
    "Memory",
    "KnowledgeArtifact"
  ],
  "produced_outputs": [
    "projection-file",
    "receipt:ProjectionReceipt"
  ],
  "side_effect_level": "local-files",
  "requires_review": true,
  "requires_network": false,
  "fallback_policy": "skip-with-receipt",
  "supported_surfaces": [
    "cli",
    "mcp",
    "workbench"
  ],
  "healthcheck": "plugin.health.portable-harness-projection"
}
