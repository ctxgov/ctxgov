{
  "schema_id": "ctxvault.case-study.claim-lint/v1",
  "target": {
    "name": "<target-name>",
    "pinned_ref": "<commit-tag-release-doc-version>"
  },
  "authority_layers": {
    "claim": "source-bound descriptive claims only",
    "context": "selected and caveated evidence only",
    "memory": "blocked until lifecycle and rollback exist",
    "action": "blocked until side-effect approval exists"
  },
  "claim_classes": [
    "quality",
    "security",
    "performance",
    "compatibility",
    "maintainer_endorsement",
    "stable_protocol",
    "runtime_behavior",
    "target_write"
  ],
  "allowed_claims": [],
  "blocked_claims": [],
  "safe_rewrites": [
    {
      "unsafe_claim": "<unsupported-quality-security-performance-compatibility-or-endorsement-claim>",
      "blocked_reason": "<missing-evidence-or-unsupported-authority-layer>",
      "safe_rewrite": "<source-bound-wording-that-does-not-overclaim>"
    }
  ],
  "missing_evidence": [],
  "publication_decision": "blocked_until_owner_approval",
  "side_effect_boundary": {
    "public_publication_performed": false,
    "target_repo_cloned": false,
    "target_file_written": false,
    "runtime_or_adapter_executed": false,
    "provider_or_model_call_performed": false,
    "memory_promotion_performed": false
  },
  "rollback": "<delete-or-supersede-claim-lint-preview>"
}
