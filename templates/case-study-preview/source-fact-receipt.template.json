{
  "schema_id": "ctxvault.case-study.source-fact-recheck/v1",
  "target": {
    "name": "<target-name>",
    "repo_url": "<https://github.com/owner/repo-or-docs-url>",
    "pinned_ref": "<commit-tag-release-doc-version>",
    "checked_at_utc": "<YYYY-MM-DDTHH:MM:SSZ>",
    "license": "<spdx-or-unknown>"
  },
  "verification_methods": [
    "primary_source"
  ],
  "source_refs": [
    "<primary-source-url>"
  ],
  "source_facts": {},
  "volatile_facts": [],
  "authority_layers": {
    "claim": "source-bound descriptive claims only",
    "context": "selected and caveated evidence only",
    "memory": "blocked until lifecycle and rollback exist",
    "action": "blocked until side-effect approval exists"
  },
  "evidence_object_schema": {
    "required_fields": [
      "ref",
      "state",
      "reason",
      "authority_layer_blocked",
      "safe_rewrite_or_next_check",
      "rollback_ref"
    ]
  },
  "selected_evidence": [
    {
      "ref": "<primary-source-url#section>",
      "state": "selected",
      "reason": "<why-this-source-can-influence-the-preview>",
      "authority_layer_blocked": null,
      "safe_rewrite_or_next_check": "<source-backed-safe-wording-or-next-check>",
      "rollback_ref": "<delete-or-supersede-local-preview-artifacts>"
    }
  ],
  "omitted_evidence": [
    {
      "ref": "<source-or-surface-not-inspected>",
      "state": "omitted",
      "reason": "<why-it-is-not-authority-yet>",
      "authority_layer_blocked": "claim|context|memory|action",
      "safe_rewrite_or_next_check": "<next-source-check-or-safe-caveat>",
      "rollback_ref": "<delete-or-supersede-local-preview-artifacts>"
    }
  ],
  "blocked_evidence": [],
  "stale_or_conflicting_evidence": [],
  "missing_evidence": [],
  "side_effect_boundary": {
    "target_repo_cloned": false,
    "target_file_written": false,
    "runtime_or_adapter_executed": false,
    "mcp_server_started": false,
    "provider_or_model_call_performed": false,
    "memory_promotion_performed": false,
    "github_public_repo_write_performed": false
  },
  "rollback": "<delete-or-supersede-local-preview-artifacts>"
}
