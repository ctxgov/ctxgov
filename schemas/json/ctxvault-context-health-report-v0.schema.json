{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctxvault.local/schemas/ctxvault-context-health-report-v0.schema.json",
  "title": "CtxVault Context Health Report v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "report_id",
    "generated_at",
    "scanned_path",
    "mode",
    "output_policy",
    "decision_table",
    "summary",
    "findings",
    "evidence",
    "side_effects",
    "rollback"
  ],
  "properties": {
    "schema_id": {
      "type": "string",
      "enum": ["ctxvault.context-health-report/v0"]
    },
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "scanned_path": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["read_only_local_scan"]
    },
    "output_policy": {
      "$ref": "#/$defs/OutputPolicy"
    },
    "decision_table": {
      "$ref": "#/$defs/DecisionTable"
    },
    "summary": {
      "$ref": "#/$defs/Summary"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Finding"
      }
    },
    "evidence": {
      "$ref": "#/$defs/EvidenceAccounting"
    },
    "side_effects": {
      "$ref": "#/$defs/SideEffects"
    },
    "rollback": {
      "$ref": "#/$defs/Rollback"
    }
  },
  "$defs": {
    "OutputPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_root",
        "health_root",
        "backup_root",
        "raw_source_copied",
        "target_files_written"
      ],
      "properties": {
        "output_root": {
          "type": "string",
          "minLength": 1
        },
        "health_root": {
          "type": "string",
          "minLength": 1
        },
        "backup_root": {
          "type": "string",
          "minLength": 1
        },
        "raw_source_copied": {
          "type": "boolean"
        },
        "target_files_written": {
          "type": "boolean"
        }
      }
    },
    "DecisionTable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "context", "memory", "action"],
      "properties": {
        "claim": {
          "$ref": "#/$defs/Decision"
        },
        "context": {
          "$ref": "#/$defs/Decision"
        },
        "memory": {
          "$ref": "#/$defs/Decision"
        },
        "action": {
          "$ref": "#/$defs/Decision"
        }
      }
    },
    "Decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason", "next_check", "rollback"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["allowed", "caveated", "blocked"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "next_check": {
          "type": "string",
          "minLength": 1
        },
        "rollback": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_count", "severity_counts", "finding_type_counts"],
      "properties": {
        "finding_count": {
          "type": "integer",
          "minimum": 0
        },
        "severity_counts": {
          "type": "object"
        },
        "finding_type_counts": {
          "type": "object"
        }
      }
    },
    "Finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "source_ref",
        "finding_type",
        "authority_layer_affected",
        "severity",
        "reason",
        "safe_rewrite_or_next_check",
        "rollback_ref"
      ],
      "properties": {
        "finding_id": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "finding_type": {
          "type": "string",
          "enum": [
            "stale_context",
            "conflicting_instruction",
            "duplicated_rule",
            "private_public_boundary_risk",
            "unsupported_claim",
            "release_link_404",
            "package_registry_unverified",
            "release_artifact_missing",
            "missing_raw_ref",
            "over_compressed_summary",
            "memory_without_lifecycle_or_rollback",
            "memory_missing_source_coverage",
            "memory_missing_rollback",
            "memory_unbounded_consequence",
            "memory_missing_model_state_surface",
            "action_or_publication_without_evidence",
            "task_shard_schema_conflict",
            "task_shard_unapproved_side_effect",
            "task_shard_missing_rollback",
            "terminal_failure_hidden"
          ]
        },
        "evidence_span": {
          "type": "string",
          "minLength": 1
        },
        "authority_layer_affected": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["claim", "context", "memory", "action"]
          }
        },
        "severity": {
          "type": "string",
          "enum": ["info", "low", "medium", "high", "critical"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "safe_rewrite_or_next_check": {
          "type": "string",
          "minLength": 1
        },
        "rollback_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "EvidenceAccounting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_refs",
        "omitted_refs",
        "blocked_refs",
        "stale_refs",
        "conflicting_refs",
        "caveated_refs"
      ],
      "properties": {
        "selected_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "omitted_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocked_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stale_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "conflicting_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "caveated_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "SideEffects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network_fetch_performed",
        "provider_or_model_call_performed",
        "runtime_or_adapter_executed",
        "browser_or_cloud_state_read",
        "mcp_server_started",
        "target_file_written",
        "memory_promotion_performed",
        "raw_source_copied",
        "public_publication_performed",
        "stable_protocol_claim"
      ],
      "properties": {
        "network_fetch_performed": {
          "type": "boolean"
        },
        "provider_or_model_call_performed": {
          "type": "boolean"
        },
        "runtime_or_adapter_executed": {
          "type": "boolean"
        },
        "browser_or_cloud_state_read": {
          "type": "boolean"
        },
        "mcp_server_started": {
          "type": "boolean"
        },
        "target_file_written": {
          "type": "boolean"
        },
        "memory_promotion_performed": {
          "type": "boolean"
        },
        "raw_source_copied": {
          "type": "boolean"
        },
        "public_publication_performed": {
          "type": "boolean"
        },
        "stable_protocol_claim": {
          "type": "boolean"
        }
      }
    },
    "Rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rollback_ref", "delete_paths", "supersede_with"],
      "properties": {
        "rollback_ref": {
          "type": "string",
          "minLength": 1
        },
        "delete_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "supersede_with": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
