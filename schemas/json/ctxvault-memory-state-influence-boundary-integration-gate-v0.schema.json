{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ctxvault-memory-state-influence-boundary-integration-gate-v0.schema.json",
  "title": "CtxVault Memory State Influence Boundary Integration Gate",
  "description": "Local v0 gate payload emitted by --format gate. This is an integration contract for local tooling, not a stable protocol or provider compatibility claim.",
  "type": "object",
  "required": [
    "schema_id",
    "mode",
    "passed",
    "default_exit_code",
    "fail_on_blocked_exit_code",
    "blocked_ref_count",
    "omitted_ref_count",
    "stale_or_superseded_ref_count",
    "imported_context_ref_count",
    "raw_content_included",
    "policy",
    "recommendation"
  ],
  "properties": {
    "schema_id": {
      "const": "ctxvault.memory-state-influence-boundary-integration-gate/v0"
    },
    "mode": {
      "const": "fail_on_blocked"
    },
    "passed": {
      "type": "boolean"
    },
    "default_exit_code": {
      "type": "integer",
      "enum": [0, 1]
    },
    "fail_on_blocked_exit_code": {
      "type": "integer",
      "enum": [0, 1, 2]
    },
    "blocked_ref_count": {
      "type": "integer",
      "minimum": 0
    },
    "omitted_ref_count": {
      "type": "integer",
      "minimum": 0
    },
    "stale_or_superseded_ref_count": {
      "type": "integer",
      "minimum": 0
    },
    "imported_context_ref_count": {
      "type": "integer",
      "minimum": 0
    },
    "raw_content_included": {
      "const": false
    },
    "policy": {
      "type": "string",
      "minLength": 1
    },
    "recommendation": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
