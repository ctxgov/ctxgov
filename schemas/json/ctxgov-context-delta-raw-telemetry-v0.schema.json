{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctxgov.local/schemas/ctxgov-context-delta-raw-telemetry-v0.schema.json",
  "title": "CtxGov Context Delta Raw Telemetry v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "object_type",
    "version",
    "created_at",
    "telemetry_id",
    "trace_ref",
    "measurement_boundary",
    "raw_counts",
    "rows",
    "claim_boundary",
    "side_effect_boundary",
    "rollback_ref"
  ],
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "ctxgov.context-delta-raw-telemetry/v0",
      "enum": ["ctxgov.context-delta-raw-telemetry/v0"]
    },
    "object_type": {
      "type": "string",
      "const": "ContextDeltaRawTelemetry",
      "enum": ["ContextDeltaRawTelemetry"]
    },
    "version": {
      "type": "string",
      "const": "v0",
      "enum": ["v0"]
    },
    "created_at": { "$ref": "#/$defs/Timestamp" },
    "telemetry_id": { "$ref": "#/$defs/NonEmptyString" },
    "trace_ref": { "$ref": "#/$defs/NonEmptyString" },
    "measurement_boundary": { "$ref": "#/$defs/MeasurementBoundary" },
    "raw_counts": { "$ref": "#/$defs/RawCounts" },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/TelemetryRow" }
    },
    "claim_boundary": { "$ref": "#/$defs/ClaimBoundary" },
    "side_effect_boundary": { "$ref": "#/$defs/SideEffectBoundary" },
    "rollback_ref": { "$ref": "#/$defs/NonEmptyString" }
  },
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "Timestamp": {
      "type": "string",
      "minLength": 1
    },
    "MeasurementBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit", "raw_counts_only", "interpretation", "derived_claim_created"],
      "properties": {
        "unit": {
          "type": "string",
          "enum": ["context_unit"]
        },
        "raw_counts_only": {
          "type": "boolean",
          "enum": [true]
        },
        "interpretation": {
          "type": "string",
          "enum": ["raw_counts_only_no_conclusion"]
        },
        "derived_claim_created": {
          "type": "boolean",
          "enum": [false]
        }
      }
    },
    "RawCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "before_context_unit_count",
        "after_context_unit_count",
        "added_context_unit_count",
        "removed_context_unit_count",
        "changed_context_unit_count"
      ],
      "properties": {
        "before_context_unit_count": { "type": "integer", "minimum": 0 },
        "after_context_unit_count": { "type": "integer", "minimum": 0 },
        "added_context_unit_count": { "type": "integer", "minimum": 0 },
        "removed_context_unit_count": { "type": "integer", "minimum": 0 },
        "changed_context_unit_count": { "type": "integer", "minimum": 0 }
      }
    },
    "TelemetryRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_ref", "before_count", "after_count", "change_count"],
      "properties": {
        "source_ref": { "$ref": "#/$defs/NonEmptyString" },
        "before_count": { "type": "integer", "minimum": 0 },
        "after_count": { "type": "integer", "minimum": 0 },
        "change_count": { "type": "integer" }
      }
    },
    "ClaimBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_claim_created",
        "comparative_outcome_claim_created",
        "external_use_claim_created",
        "readiness_or_certification_claim_created",
        "universal_fit_claim_created",
        "result_authority_claim_created",
        "protocol_guarantee_claim_created"
      ],
      "properties": {
        "public_claim_created": { "type": "boolean", "enum": [false] },
        "comparative_outcome_claim_created": { "type": "boolean", "enum": [false] },
        "external_use_claim_created": { "type": "boolean", "enum": [false] },
        "readiness_or_certification_claim_created": { "type": "boolean", "enum": [false] },
        "universal_fit_claim_created": { "type": "boolean", "enum": [false] },
        "result_authority_claim_created": { "type": "boolean", "enum": [false] },
        "protocol_guarantee_claim_created": { "type": "boolean", "enum": [false] }
      }
    },
    "SideEffectBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network_call_performed",
        "provider_model_call_performed",
        "api_call_performed",
        "live_model_call_performed",
        "scheduler_or_daemon_started",
        "target_file_written",
        "public_repo_written",
        "package_published"
      ],
      "properties": {
        "network_call_performed": { "type": "boolean", "enum": [false] },
        "provider_model_call_performed": { "type": "boolean", "enum": [false] },
        "api_call_performed": { "type": "boolean", "enum": [false] },
        "live_model_call_performed": { "type": "boolean", "enum": [false] },
        "scheduler_or_daemon_started": { "type": "boolean", "enum": [false] },
        "target_file_written": { "type": "boolean", "enum": [false] },
        "public_repo_written": { "type": "boolean", "enum": [false] },
        "package_published": { "type": "boolean", "enum": [false] }
      }
    }
  }
}
