{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctxvault.local/schemas/ctxvault-task-shard-context-import-shapes-v0.schema.json",
  "title": "CtxGov Task Shard Context Import Shapes v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_id",
    "object_type",
    "version",
    "status",
    "created_at",
    "product_line",
    "import_shapes",
    "claim_gate",
    "side_effect_boundary",
    "rollback"
  ],
  "properties": {
    "schema_id": { "const": "ctxvault.task-shard-context-import-shapes/v0" },
    "object_type": { "const": "TaskShardContextImportShapes" },
    "version": { "const": "post-v0.7.0" },
    "status": { "const": "private_import_shape_only_no_runtime" },
    "product_line": { "const": "Task Shard Context Control" },
    "import_shapes": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": [
          "import_surface_id",
          "surface_family",
          "adapter_layer",
          "runtime_execution_allowed",
          "expected_artifacts",
          "mapped_read_models",
          "context_ref_contract",
          "side_effect_boundary",
          "claim_gate"
        ],
        "properties": {
          "import_surface_id": {
            "enum": [
              "claude_dynamic_workflows",
              "cline_task_history",
              "openhands_condenser_trace",
              "aider_repo_map",
              "plandex_context_map"
            ]
          },
          "adapter_layer": { "const": "offline_import_shape_only" },
          "runtime_execution_allowed": { "const": false },
          "expected_artifacts": { "type": "array", "minItems": 1 },
          "mapped_read_models": { "type": "array", "minItems": 1 },
          "context_ref_contract": {
            "type": "object",
            "required": [
              "selected_source_ref_fields",
              "omitted_context_ref_fields",
              "source_recovery_required",
              "omitted_context_visible"
            ],
            "properties": {
              "selected_source_ref_fields": { "type": "array", "minItems": 1 },
              "omitted_context_ref_fields": { "type": "array", "minItems": 1 },
              "source_recovery_required": { "const": true },
              "omitted_context_visible": { "const": true }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "claim_gate": {
      "type": "object",
      "properties": {
        "public_benchmark_claim_allowed": { "const": false },
        "public_efficiency_claim_allowed": { "const": false },
        "public_adoption_claim_allowed": { "const": false },
        "public_compatibility_claim_allowed": { "const": false },
        "stable_mgp_claim_allowed": { "const": false }
      },
      "additionalProperties": true
    },
    "side_effect_boundary": {
      "type": "object",
      "properties": {
        "fixture_pack_created": { "const": true },
        "live_workflow_executed": { "const": false },
        "worktree_created": { "const": false },
        "provider_or_model_call_performed": { "const": false },
        "runtime_or_adapter_executed": { "const": false },
        "target_file_written": { "const": false },
        "memory_backend_written": { "const": false },
        "memory_promotion_performed": { "const": false },
        "public_claim_created": { "const": false }
      },
      "additionalProperties": true
    }
  }
}
