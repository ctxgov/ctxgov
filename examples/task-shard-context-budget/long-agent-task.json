{
  "schema_id": "ctxgov.task-shard-context-budget-example/v0",
  "example_id": "long-agent-task-public-safe",
  "task": "Update a documentation site from saved local evidence without executing the workflow.",
  "shards": [
    {
      "shard_id": "shard-1-source-intake",
      "allowed_context_refs": [
        "source://repo-readme",
        "source://release-notes"
      ],
      "omitted_context_refs": [
        "source://private-terminal-log"
      ],
      "max_tokens": 1800
    },
    {
      "shard_id": "shard-2-claim-review",
      "allowed_context_refs": [
        "source://claim-boundary",
        "source://release-receipt"
      ],
      "omitted_context_refs": [
        "source://owner-private-chat"
      ],
      "max_tokens": 1600
    },
    {
      "shard_id": "shard-3-public-copy",
      "allowed_context_refs": [
        "source://approved-copy",
        "source://public-page"
      ],
      "omitted_context_refs": [
        "source://unapproved-benchmark-note"
      ],
      "max_tokens": 1400
    }
  ],
  "side_effect_boundary": {
    "workflow_executed": false,
    "worktree_created": false,
    "provider_or_model_call_performed": false,
    "target_file_written": false,
    "memory_backend_written": false
  }
}
